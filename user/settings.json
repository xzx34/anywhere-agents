{
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/guard.py\" 2>/dev/null || python \"$HOME/.claude/hooks/guard.py\"",
            "statusMessage": "Checking for compound cd and destructive commands..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/hooks/session_bootstrap.py\" 2>/dev/null || python \"$HOME/.claude/hooks/session_bootstrap.py\"",
            "statusMessage": "Running anywhere-agents bootstrap if present..."
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "AGENT_CONFIG_GIT_GATES": "off"
  }
}
